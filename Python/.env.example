# =============================================================================
# .env.example  --  TEMPLATE 
# =============================================================================
# This file documents which secret keys the project needs, WITHOUT containing
# any real values. To use it:
#   1. Make a copy of this file and rename the copy to ".env"
#   2. Replace the placeholder text with real credentials
#   3. Keep ".env" private; never share or submit it
# =============================================================================

# Gmail 16-character App Password (no spaces).
EMAIL_APP_PASSWORD=your_gmail_app_password_here

# ThingSpeak channel Write API Key.
THINGSPEAK_WRITE_KEY=your_thingspeak_write_key_here
